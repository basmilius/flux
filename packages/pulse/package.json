{
    "name": "pulse",
    "description": "Pulse — a product & web analytics dashboard demo built on every Flux UI package.",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "vue-tsc --noEmit && vite build",
        "build:no-check": "vite build",
        "check": "vue-tsc --noEmit",
        "preview": "vite preview"
    },
    "engines": {
        "node": ">=23"
    },
    "dependencies": {
        "@basmilius/common": "^3.43.0",
        "@flux-ui/application": "workspace:*",
        "@flux-ui/components": "workspace:*",
        "@flux-ui/internals": "workspace:*",
        "@flux-ui/statistics": "workspace:*",
        "@flux-ui/types": "workspace:*",
        "@faker-js/faker": "^10.4.0",
        "@fortawesome/fontawesome-common-types": "^7.2.0",
        "@fortawesome/pro-regular-svg-icons": "^7.2.0",
        "clsx": "^2.1.1",
        "echarts": "^6.1.0",
        "luxon": "^3.7.2",
        "vue": "^3.6.0-beta.16",
        "vue-i18n": "^11.4.5",
        "vue-router": "^5.1.0"
    },
    "devDependencies": {
        "@basmilius/vite-preset": "^3.43.0",
        "@types/luxon": "^3.7.1",
        "@types/node": "^25.9.3",
        "@vitejs/plugin-vue": "^6.0.7",
        "@vue/tsconfig": "^0.9.1",
        "sass-embedded": "^1.100.0",
        "vite": "^8.0.16",
        "vue-tsc": "^3.3.5"
    }
